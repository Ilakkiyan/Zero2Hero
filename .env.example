# ── Pick ONE provider ──────────────────────────────────────────────
# Which backend lib/llm.ts talks to: "ollama" | "gemini" | "azure"
# Default is fully local via Ollama (no API key needed).
LLM_PROVIDER=azure

# ── Azure OpenAI (Azure for Students $100 credit) ──────────────────
# Endpoint looks like https://<resource>.openai.azure.com
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-06-01

# ── Web research search backend ────────────────────────────────────
# Default: local SearxNG (no key). Start it with:
#   docker compose -f docker-compose.searxng.yml up -d
# Or bring a Gemini key (below / in-app Key button) to use cloud grounding.
SEARXNG_URL=http://localhost:8080

# ── Google Gemini (optional — cloud research only) ─────────────────
# Key from https://aistudio.google.com/apikey
# OPTIONAL fallback: users can bring their own key in the UI (stored in their
# browser, sent per-request). Leave GEMINI_API_KEY UNSET in production to force
# bring-your-own-key so your quota is never spent by visitors.
GEMINI_API_KEY=
# 2.0-flash free tier is retired (quota 0); use 2.5-flash on the free tier.
GEMINI_MODEL=gemini-2.5-flash

# ── Ollama (local, free, unlimited — the default) ──────────────────
# Install from https://ollama.com/download, then: ollama pull qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
# Optional: context window in tokens (default 4096). Larger = more VRAM.
# OLLAMA_NUM_CTX=8192
# Optional: only for qwen3-style reasoning models — set "true" to isolate the
# <think> trace out of the reply (or "false" to disable). Leave UNSET for
# qwen2.5 and other non-reasoning models, which reject this parameter (400).
# OLLAMA_THINK=true

# ── Google Calendar sync (optional) ────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# (Web application). Enable the Google Calendar API. Add the redirect URI
# below to the client's "Authorized redirect URIs". On the OAuth consent
# screen (External, Testing), add your Google account as a test user.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback
